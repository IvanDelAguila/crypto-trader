# Binance Testnet API Keys
# Obtén las tuyas en: https://testnet.binancefuture.com
BINANCE_API_KEY=tu_api_key_aqui
BINANCE_API_SECRET=tu_api_secret_aqui

# Modo: "paper" (sin API key, solo simula) o "testnet" (usa Binance Testnet)
TRADE_MODE=paper

# Capital inicial en USDT
INITIAL_CAPITAL=500

# Apalancamiento (1-5 recomendado)
LEVERAGE=3

# Puerto del servidor API (para el dashboard)
PORT=3001

# Riesgo máximo por trade (% del capital)
MAX_RISK_PER_TRADE=15

# Confianza mínima para abrir posición (0-100)
MIN_CONFIDENCE=70

# Activa/desactiva trading automático al arrancar
AUTO_TRADE=false
